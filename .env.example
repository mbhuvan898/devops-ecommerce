# Copy to .env — docker-compose.yml substitutes these into service env vars.
# Everything is optional for a local boot; fill in what you need.

JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRE=7d
COOKIE_EXPIRE=5
FRONTEND_URL=http://localhost:8080

# SendGrid (password reset + order emails)
SENDGRID_API_KEY=
SENDGRID_MAIL=
SENDGRID_RESET_TEMPLATEID=
SENDGRID_ORDER_TEMPLATEID=

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_SECRET=

# AWS S3 (product images) — locally use keys; on AWS use IAM roles
# Same region as the EKS/DocumentDB stack in terraform/ — keeps everything
# in one region to avoid cross-region data transfer charges.
AWS_REGION=ap-south-1
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
