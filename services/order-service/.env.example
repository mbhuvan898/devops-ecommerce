# order-service — owns the orders database
PORT=4003
NODE_ENV=development

# Each service gets its OWN database (decentralized data ownership)
MONGO_URI=mongodb://mongo:27017/orders

# Shared across all services so any of them can verify tokens
JWT_SECRET=change-me-to-a-long-random-string

# CORS origin of the frontend
FRONTEND_URL=http://localhost:8080

# Where to reach product-service for stock decrements
PRODUCT_SERVICE_URL=http://product-service:4002

# Where to reach user-service for customer name/email on order details
USER_SERVICE_URL=http://user-service:4001

# SendGrid (order confirmation emails)
SENDGRID_API_KEY=
SENDGRID_MAIL=
SENDGRID_ORDER_TEMPLATEID=
