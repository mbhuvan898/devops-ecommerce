# product-service — owns the products database, handles S3 image uploads
PORT=4002
NODE_ENV=development

# Each service gets its OWN database (decentralized data ownership)
MONGO_URI=mongodb://mongo:27017/products

# Shared across all services so any of them can verify tokens
JWT_SECRET=change-me-to-a-long-random-string

# CORS origin of the frontend
FRONTEND_URL=http://localhost:8080

# S3 image uploads (credentials come from the AWS SDK default chain / IAM role)
AWS_REGION=ap-south-2
AWS_S3_BUCKET=
