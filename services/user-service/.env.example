# user-service — owns the users database, issues JWTs, sends emails
PORT=4001
NODE_ENV=development

# Each service gets its OWN database (decentralized data ownership)
MONGO_URI=mongodb://mongo:27017/users

# Shared across all services so any of them can verify tokens
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRE=7d
COOKIE_EXPIRE=5

# CORS origin of the frontend
FRONTEND_URL=http://localhost:8080

# Where to reach order-service for the user's order count
ORDER_SERVICE_URL=http://order-service:4003

# SendGrid (password reset + order emails)
SENDGRID_API_KEY=
SENDGRID_MAIL=
SENDGRID_RESET_TEMPLATEID=
SENDGRID_ORDER_TEMPLATEID=
